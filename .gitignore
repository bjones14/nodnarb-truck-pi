#  Ignore EVERYTHING in the home directory by default

/*

# Explicitly ALLOW (un-ignore) your truck project files

!dashcam.py
!telemetry.py
!config.json
!.gitignore
!README.md
!telemetry.service
!dashcam.service

# Explicitly allow the .git folder (required for git to work)

!.git/

